# Neon Postgres
DATABASE_URL="postgres://user:password@host:port/db-name"

# Auth.js + GitHub OAuth
AUTH_SECRET="replace-with-at-least-32-random-characters"
AUTH_TRUST_HOST=true
AUTH_GITHUB_ID=""
